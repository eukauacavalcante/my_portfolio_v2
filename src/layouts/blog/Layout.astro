---
import '../../styles/global.css';
import Header from '@/components/layout/Header.astro';
import GridBackgroundDemo from "@/components/ui/GridBackgroundDemo";
import Footer from '@/components/layout/Footer.astro';
import Head from '@/components/metadata/Head.astro';

const { pageTitle, pageDescription, class: className } = Astro.props;
---

<html lang="pt-BR" class="dark">
    <head>
        <Head title={pageTitle} description={pageDescription} canonicalUrl={Astro.url.href} />
    </head>
    <body class=`${className} bg-background text-primary selection:bg-primary selection:text-primary-foreground overflow-x-hidden`>
        <div class="fixed inset-0 -z-10">
            <GridBackgroundDemo client:load />
        </div>

        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>
