---
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import TagButton from "./TagButton.astro";
import { Image } from "astro:assets";

const post = Astro.props.post;
---

<Card
    size="full"
    hover
    class="flex flex-col overflow-hidden p-0 border-border backdrop-blur-sm group"
>
    {post.frontmatter.image?.url && (
        <div class="w-full h-44 sm:h-58 overflow-hidden shrink-0">
            { post.frontmatter.image?.url ? (
                <Image
                    src={"/" + post.frontmatter.image.url}
                    alt={post.frontmatter.image.alt ?? post.frontmatter.title}
                    width={800}
                    height={450}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
            ) : (
                <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24">
                        <path fill="currentColor" d="M17 12c0 .54-.1 1.05-.26 1.54L15 11.78A3.06 3.06 0 0 0 12.22 9l-1.76-1.74c.49-.16 1-.26 1.54-.26c2.76 0 5 2.24 5 5M9.88 4h4.24l1.83 2H20v10.8l1.88 1.88c.08-.21.12-.44.12-.68V6c0-1.11-.89-2-2-2h-3.17L15 2H9L7.18 4L8.6 5.4zm12.23 17.46l-1.27 1.27L18.11 20H4a2 2 0 0 1-2-2V6c0-.58.25-1.1.65-1.46L1.11 3l1.28-1.27zM9 12c0 1.66 1.34 3 3 3c.33 0 .65-.07.94-.17l-3.77-3.77c-.1.3-.17.61-.17.94m7.11 6l-1.66-1.66c-.73.41-1.56.66-2.45.66c-2.76 0-5-2.24-5-5c0-.89.25-1.72.66-2.45L4.11 6H4v12z"/>
                    </svg>
                </div>
            )}
        </div>
    )}
    <div class="flex flex-col flex-1 p-4 sm:p-5 gap-3">
        <div class="flex flex-wrap gap-2">
            {post.frontmatter.tags?.slice(0, 2).map((tag: string) => (
                <TagButton tag={tag} />
            ))}
        </div>
        <h3 class="text-base sm:text-lg font-bold leading-snug group-hover:text-gradient duration-500 transition-colors line-clamp-2">
            {post.frontmatter.title}
        </h3>
        <p class="text-muted-foreground text-sm leading-relaxed line-clamp-3 flex-1">
            // {post.frontmatter.description}
        </p>
    </div>
    <div class="flex items-center justify-between p-4 border-t border-border mt-auto">
        <div class="flex flex-col gap-1.5">
            <span class="text-xs text-muted-foreground flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M19 19H5V8h14m-3-7v2H8V1H6v2H5c-1.11 0-2 .89-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-1V1m-1 11h-5v5h5z"/>
                </svg>
                {new Date(post.frontmatter.publishedOn).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
            </span>
            <span class="text-xs text-muted-foreground flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M12 2A10 10 0 0 0 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2m4.2 14.2L11 13V7h1.5v5.2l4.5 2.7z"/>
                </svg>
                {post.frontmatter.readingTime} min de leitura
            </span>
        </div>
        <Button href={post.url} class="shrink-0 group">
            <span>Ler mais</span>
            <svg class="group-hover:translate-x-1 transition" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                <path stroke-dasharray="20" d="M3 12h17.5"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.3s" values="20;0"/></path><path stroke-dasharray="12" stroke-dashoffset="12" d="M21 12l-7 7M21 12l-7 -7"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.3s" dur="0.2s" to="0"/></path></g>
            </svg>
        </Button>
    </div>
</Card>
