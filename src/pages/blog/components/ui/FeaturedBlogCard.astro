---
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "astro-iconify";
import TagButton from "./TagButton.astro";
import { Image } from "astro:assets";

const featured = Astro.props.featured;
---

<Card
    size="full"
    hover
    class="flex flex-col md:flex-row md:h-auto xl:h-105 p-0 overflow-hidden group"
>
    {featured.frontmatter.image?.url && (
        <div class="w-full md:w-2/5 h-52 sm:h-64 md:h-auto overflow-hidden shrink-0">
            <Image
                src={"/" + featured.frontmatter.image.url}
                alt={featured.frontmatter.image.alt ?? featured.frontmatter.title}
                width={800}
                height={450}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
        </div>
    )}
    <div class="flex flex-col justify-between gap-4 p-5 sm:p-7 md:p-8 flex-1 border-t md:border-t-0 md:border-l border-border">
        <div class="flex flex-col gap-3">
            <div class="flex">
                <span class="text-[10px] sm:text-xs font-semibold bg-foreground text-primary-foreground px-2 py-0.5 rounded">
                    Mais recente
                </span>
            </div>
            <h3 class="text-xl sm:text-2xl md:text-3xl font-bold leading-snug group-hover:text-gradient duration-500 transition-colors line-clamp-3">
                {featured.frontmatter.title}
            </h3>
            <p class="text-muted-foreground text-sm sm:text-base font-mono line-clamp-3">
                // {featured.frontmatter.description}
            </p>
            <span class="flex flex-wrap gap-2">
                {featured.frontmatter.tags?.slice(0, 2).map((tag: string) => (
                    <TagButton tag={tag} />
                ))}
            </span>
        </div>
        <div class="flex items-end justify-between gap-4 mt-auto pt-4 border-t border-border">
            <div class="flex flex-col gap-1.5">
                <span class="text-xs text-muted-foreground flex items-center gap-1">
                    <Icon name="mdi:calendar-month-outline" class="w-3.5 h-3.5 inline-block" />
                    {new Date(featured.frontmatter.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                </span>
                <span class="text-xs text-muted-foreground flex items-center gap-1">
                    <Icon name="lucide:clock" class="w-3.5 h-3.5 inline-block" />
                    {featured.frontmatter.readingTime} min de leitura
                </span>
            </div>
            <Button href={featured.url} class="shrink-0 group">
                <span>Ler mais</span>
                <Icon name="mdi:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition" />
            </Button>
        </div>
    </div>
</Card>
