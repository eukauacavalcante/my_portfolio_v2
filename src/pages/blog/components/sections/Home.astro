---
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "astro-iconify";

const allPosts = Object.values(import.meta.glob('../../posts/*.md', { eager: true })) as any[];

// Sort by pubDate descending
const sortedPosts = allPosts.sort((a, b) =>
    new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const [featured, ...restPosts] = sortedPosts;

// Group remaining posts in pairs
const postPairs: any[][] = [];
for (let i = 0; i < restPosts.length; i += 2) {
    postPairs.push(restPosts.slice(i, i + 2));
}
---

<section class="min-h-svh flex flex-col w-full py-12 sm:py-16 lg:py-24 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">

    <div class="flex flex-row gap-4 mb-4 text-xs sm:text-base">
        <span class="text-muted-foreground hover:text-primary transition-all">
            <a href="/">
                Home
            </a>
        </span>
        <span class="text-muted-foreground">/</span>
        <span class="text-primary font-semibold">Blog Pessoal</span>
    </div>
    <div class="flex flex-col gap-3 mb-12 sm:mb-16">
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
            Blog Pessoal
        </h1>
        <p class="text-sm sm:text-base md:text-lg text-muted-foreground font-mono max-w-xl mt-1">
            // Pensamentos, projetos e aprendizados do dia a dia.
        </p>
    </div>

    <div class="flex flex-col gap-4 sm:gap-6">
        <h2 class="text-sm font-mono text-muted-foreground tracking-widest uppercase flex items-center gap-3">
            <span class="h-px w-5 bg-border inline-block"></span>
            Últimas postagens
        </h2>
        {featured && (
            <Card size="full" hover class="p-0 overflow-hidden">
                <a href={featured.url} class="group flex flex-col sm:flex-row w-full gap-0">
                    {featured.frontmatter.image?.url && (
                        <div class="w-full sm:w-2/5 h-48 sm:h-auto overflow-hidden shrink-0">
                            <img
                                src={featured.frontmatter.image.url}
                                alt={featured.frontmatter.image.alt ?? featured.frontmatter.title}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    )}
                    <div class="flex flex-col justify-between gap-4 p-6 sm:p-8 flex-1">
                        <div class="flex flex-col gap-3">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-xs font-mono bg-foreground text-primary-foreground px-2 py-0.5 rounded">
                                    Mais recente
                                </span>
                                {featured.frontmatter.tags?.slice(0, 2).map((tag: string) => (
                                    <a
                                        href={`/blog/tags/${tag}`}
                                        class="text-xs font-mono text-muted-foreground border border-border px-2 py-0.5 rounded hover:border-foreground/40 transition-colors"
                                        onclick="event.stopPropagation()"
                                    >
                                        #{tag}
                                    </a>
                                ))}
                            </div>
                            <h3 class="text-2xl sm:text-3xl font-bold leading-snug group-hover:text-foreground/80 transition-colors">
                                {featured.frontmatter.title}
                            </h3>
                            <p class="text-muted-foreground text-sm sm:text-base leading-relaxed line-clamp-3">
                                {featured.frontmatter.description}
                            </p>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-xs text-muted-foreground font-mono">
                                {new Date(featured.frontmatter.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                            </span>
                            <Button href={featured.url} size="sm">
                                Ler mais
                                <Icon name="mdi:arrow-right" class="w-4 h-4" />
                            </Button>
                        </div>
                    </div>
                </a>
            </Card>
        )}

        <div class="w-full max-w-6xl mx-auto"> 
            {postPairs.map((pair) => (
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mb-6">
                    {pair.map((post: any) => (
                        <Card size="full" hover class="flex flex-col justify-between border-border bg-card/50 backdrop-blur-sm">
                            <div class="flex flex-col gap-3 mb-4">
                                {post.frontmatter.image?.url && (
                                    <div class="w-full h-48 overflow-hidden rounded-t-lg shrink-0">
                                        <img
                                            src={post.frontmatter.image.url}
                                            alt={post.frontmatter.image.alt ?? post.frontmatter.title}
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                        />
                                    </div>
                                )}
                                <div class="p-4 flex flex-col gap-3">
                                    <div class="flex flex-wrap gap-2">
                                        {post.frontmatter.tags?.slice(0, 2).map((tag: string) => (
                                            <a
                                                href={`/blog/tags/${tag}`}
                                                class="text-[10px] font-mono text-muted-foreground border border-border px-2 py-0.5 rounded hover:border-chart-1/50 hover:text-chart-1 transition-colors"
                                            >
                                                #{tag}
                                            </a>
                                        ))}
                                    </div>
                                    <h3 class="text-xl font-bold leading-snug group-hover:text-chart-1 transition-colors">
                                        {post.frontmatter.title}
                                    </h3>
                                    <p class="text-muted-foreground text-sm leading-relaxed line-clamp-3 font-sans">
                                        {post.frontmatter.description}
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-4 border-t border-border mt-auto">
                                <span class="text-xs text-muted-foreground font-mono">
                                    {new Date(post.frontmatter.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
                                </span>
                                <Button href={post.url} size="sm" variant="outline" class="hover:border-chart-1 hover:text-chart-1">
                                    Ler mais
                                    <Icon name="mdi:arrow-right" class="w-4 h-4" />
                                </Button>
                            </div>
                        </Card>
                    ))}
                </div>
            ))}
        </div>

        {sortedPosts.length === 0 && (
            <Card class="w-full py-16 flex flex-col items-center justify-center gap-3 text-center">
                <Icon name="mdi:emoticon-sad-outline" />
                <p class="text-muted-foreground font-mono text-sm">// Nenhum post ainda. Em breve...</p>
            </Card>
        )}
    </div>
</section>
