---
import { Image } from "astro:assets";
import Layout from "../../layouts/layout.astro";
import projects from "../../data/project";
import Button from "../../components/ui/Button.astro";
import Card from "../../components/ui/Card.astro";
import ImageCarousel from "@/components/ui/ImageCarousel.astro";

export function getStaticPaths() {
    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { slug } = Astro.params;
const projectFromProps = Astro.props.project;
const project = projectFromProps ?? projects.find((item) => item.slug === slug);

if (!project) {
    Astro.response.status = 404;
}

const pageTitle = project ? `${project.title}` : "Projeto nao encontrado";

const allImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/projects/**/*.{png,jpg,jpeg,webp}"
);

const singleImageModule =
    project?.images?.length === 1
        ? await allImages[project.images[0]]?.()
        : null;
---

<Layout pageTitle={pageTitle}>
    <section class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-24">
        {project ? (
            <article class="space-y-8">
                <header class="space-y-4">
                    <div class="flex flex-row gap-3 justify-start items-center mb-4 text-xs sm:text-sm">
                        <span class="text-muted-foreground hover:text-primary transition-all">
                            <a href="/#projetos">Home</a>
                        </span>
                        <span class="text-muted-foreground">/</span>
                        <span class="text-primary font-semibold">{project.title}</span>
                    </div>

                    <div class="flex flex-row justify-between items-center">
                        <h1 class="text-3xl font-extrabold leading-tight sm:text-4xl lg:text-5xl">
                            {project.title}
                        </h1>
                        <span class="text-muted-foreground font-mono">{project.date}</span>
                    </div>

                    <p class="font-mono text-sm text-muted-foreground sm:text-base">
                        // {project.phrase}
                    </p>

                    <div class="flex flex-row gap-2">
                        {project.tags.map((tag) => (
                            <span class="text-xs text-muted-foreground uppercase bg-chart-1/10 border border-border px-3 py-1.5 rounded-xl">
                                {tag}
                            </span>
                        ))}
                    </div>
                </header>

                {project.images && project.images.length > 1 ? (
                    <ImageCarousel images={project.images} alt={project.title} />
                ) : singleImageModule ? (
                    <div class="mx-auto overflow-hidden rounded-xl border border-border bg-card/40">
                        <Image
                            src={singleImageModule.default}
                            alt={project.title}
                            width={1200}
                            height={675}
                            class="h-full w-full object-cover"
                            quality={80}
                        />
                    </div>
                ) : (
                    <div class="flex aspect-video items-center justify-center text-muted-foreground bg-linear-to-tr from-chart-1/10 to-chart-2/10">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24">
                            <path fill="currentColor" d="M17 12c0 .54-.1 1.05-.26 1.54L15 11.78A3.06 3.06 0 0 0 12.22 9l-1.76-1.74c.49-.16 1-.26 1.54-.26c2.76 0 5 2.24 5 5M9.88 4h4.24l1.83 2H20v10.8l1.88 1.88c.08-.21.12-.44.12-.68V6c0-1.11-.89-2-2-2h-3.17L15 2H9L7.18 4L8.6 5.4zm12.23 17.46l-1.27 1.27L18.11 20H4a2 2 0 0 1-2-2V6c0-.58.25-1.1.65-1.46L1.11 3l1.28-1.27zM9 12c0 1.66 1.34 3 3 3c.33 0 .65-.07.94-.17l-3.77-3.77c-.1.3-.17.61-.17.94m7.11 6l-1.66-1.66c-.73.41-1.56.66-2.45.66c-2.76 0-5-2.24-5-5c0-.89.25-1.72.66-2.45L4.11 6H4v12z"/>
                        </svg>
                    </div>
                )}

                <h2 class="text-xl font-bold sm:text-2xl">Resumo</h2>
                <p class="text-base leading-relaxed text-muted-foreground">
                    {project.resume}
                </p>

                {project.isPrivate && (
                    <div class="relative bg-card border border-chart-1/30 rounded-xl p-6 sm:p-8 hover:shadow-2xl hover:shadow-chart-1/20 hover:-translate-y-1 transition-all duration-500 cursor-default">
                        <div class="flex items-start gap-4 sm:gap-6">
                            <div class="shrink-0">
                                <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-lg bg-linear-to-tr from-chart-1 to-chart-2 text-white flex items-center justify-center border border-chart-1/30">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 16 16"><path fill="currentColor" d="M3.5 1A2.5 2.5 0 0 0 1 3.5v7A2.5 2.5 0 0 0 3.5 13h1.992a2.5 2.5 0 0 1 .242-.28l.72-.72H3.5A1.5 1.5 0 0 1 2 10.5V5h10v.026a4.5 4.5 0 0 1 1 .004V3.5A2.5 2.5 0 0 0 10.5 1zm5.431 5.724l-.577-.578a.5.5 0 1 0-.708.708l.745.744q.216-.461.54-.874m-2.577.13a.5.5 0 1 0-.708-.708l-2 2a.5.5 0 0 0 0 .708l2 2a.5.5 0 0 0 .708-.708L4.707 8.5zm6.538-.83c.366.042.471.48.21.742l-.975.975a1.507 1.507 0 1 0 2.132 2.132l.975-.975c.261-.261.7-.156.742.21a3.518 3.518 0 0 1-4.676 3.723l-2.726 2.727a1.507 1.507 0 1 1-2.132-2.132L9.168 10.7a3.518 3.518 0 0 1 3.724-4.676"/></svg>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-3">
                                    <h2 class="text-lg sm:text-xl font-semibold text-foreground">
                                        Projeto em Desenvolvimento
                                    </h2>
                                </div>
                                <p class="text-muted-foreground text-sm sm:text-base leading-relaxed">
                                    {project.privateDescription}
                                </p>
                            </div>
                        </div>
                    </div>
                )}

                <div class="flex flex-row flex-wrap gap-4">
                    {project.github && (
                        <Button href={project.github} target="_blank" rel="noopener noreferrer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/>
                            </svg>
                            Ver no GitHub
                        </Button>
                    )}
                    {project.documentation && (
                        <Button variant="outline" href={project.documentation} target="_blank" rel="noopener noreferrer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M13 9h5.5L13 3.5zM6 2h8l6 6v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4c0-1.11.89-2 2-2m9 16v-2H6v2zm3-4v-2H6v2z"/>
                            </svg>
                            Ver Documentação
                        </Button>
                    )}
                    {project.website && (
                        <Button variant="outline" href={project.website} target="_blank" rel="noopener noreferrer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2m-5.15 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56M14.34 14H9.66c-.1-.66-.16-1.32-.16-2s.06-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2M12 19.96c-.83-1.2-1.5-2.53-1.91-3.96h3.82c-.41 1.43-1.08 2.76-1.91 3.96M8 8H5.08A7.92 7.92 0 0 1 9.4 4.44C8.8 5.55 8.35 6.75 8 8m-2.92 8H8c.35 1.25.8 2.45 1.4 3.56A8 8 0 0 1 5.08 16m-.82-2C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2M12 4.03c.83 1.2 1.5 2.54 1.91 3.97h-3.82c.41-1.43 1.08-2.77 1.91-3.97M18.92 8h-2.95a15.7 15.7 0 0 0-1.38-3.56c1.84.63 3.37 1.9 4.33 3.56M12 2C6.47 2 2 6.5 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2"/>
                            </svg>
                            Acessar Projeto
                        </Button>
                    )}
                    {project.linkedin && (
                        <Button variant="outline" href={project.linkedin} target="_blank" rel="noopener noreferrer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"/>
                            </svg>
                            Ver no LinkedIn
                        </Button>
                    )}
                </div>

                {project.functionalities && project.functionalities.length > 0 && (
                    <div class="space-y-6">
                        <h2 class="text-xl font-bold sm:text-2xl">Funcionalidades</h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {project.functionalities.map((func) => (
                                <Card class="flex flex-col gap-3" size="full" hover={true}>
                                    <div class="flex items-center gap-3">
                                        <div class="flex items-center justify-center p-2 rounded-lg bg-linear-to-tr from-chart-1 to-chart-2 text-white shrink-0" set:html={func.icon} />
                                        <h3 class="text-lg font-bold leading-tight">{func.title}</h3>
                                    </div>
                                    <p class="text-sm leading-relaxed text-muted-foreground">
                                        {func.description}
                                    </p>
                                </Card>
                            ))}
                        </div>
                    </div>
                )}

                {project.stack && (
                    <div class="space-y-4">
                        <h2 class="text-xl font-bold sm:text-2xl">Tecnologias</h2>
                        {project.stack.frontend && project.stack.frontend.length > 0 && (
                            <div class="space-y-2">
                                <div class="flex flex-row gap-4 items-center">
                                    <h3 class="text-sm sm:text-base font-semibold text-muted-foreground uppercase opacity-80">Frontend</h3>
                                    <span class="w-60 h-0.5 bg-linear-to-r from-chart-1 to-chart-2/0"></span>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    {project.stack.frontend.map((tech) => (
                                        <span class="text-xs text-muted-foreground uppercase bg-chart-1/10 border border-border px-3 py-1.5 rounded-xl">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}

                        {project.stack.backend && project.stack.backend.length > 0 && (
                            <div class="space-y-2">
                                <div class="flex flex-row gap-4 items-center">
                                    <h3 class="text-sm sm:text-base font-semibold text-muted-foreground uppercase opacity-80 mt-2">Backend</h3>
                                    <span class="w-60 h-0.5 bg-linear-to-r from-chart-1 to-chart-2/0"></span>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    {project.stack.backend.map((tech) => (
                                        <span class="text-xs text-muted-foreground uppercase bg-chart-1/10 border border-border px-3 py-1.5 rounded-xl">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}

                        {project.stack.database && project.stack.database.length > 0 && (
                            <div class="space-y-2">
                                <div class="flex flex-row gap-4 items-center">
                                    <h3 class="text-sm sm:text-base font-semibold text-muted-foreground uppercase opacity-80 mt-2">Banco de Dados</h3>
                                    <span class="w-60 h-0.5 bg-linear-to-r from-chart-1 to-chart-2/0"></span>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    {project.stack.database.map((tech) => (
                                        <span class="text-xs text-muted-foreground uppercase bg-chart-1/10 border border-border px-3 py-1.5 rounded-xl">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                )}
                <div class="flex justify-center border-t border-border py-6">
                    <Button
                        variant="outline"
                        href="/#projetos"
                    >
                        <svg class="group-hover:-translate-x-1 transition" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><g fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                            <path stroke-dasharray="20" d="M21 12h-17.5"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.3s" values="20;0"/></path><path stroke-dasharray="12" stroke-dashoffset="12" d="M3 12l7 7M3 12l7 -7"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.3s" dur="0.2s" to="0"/></path></g>
                        </svg>
                        Voltar
                    </Button>
                </div>
            </article>
        ) : (
            <article class="space-y-4 rounded-xl border border-border bg-card/40 p-6">
                <h1 class="text-2xl font-bold sm:text-3xl">Projeto nao encontrado</h1>
                <p class="text-muted-foreground">
                    O projeto com slug <code>{slug}</code> nao existe ou nao esta publicado.
                </p>
                <Button
                    variant="outline"
                    href="/#projetos"
                >
                    <svg class="group-hover:-translate-x-1 transition" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><g fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                        <path stroke-dasharray="20" d="M21 12h-17.5"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.3s" values="20;0"/></path><path stroke-dasharray="12" stroke-dashoffset="12" d="M3 12l7 7M3 12l7 -7"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.3s" dur="0.2s" to="0"/></path></g>
                    </svg>
                    Voltar
                </Button>
            </article>
        )}
    </section>
</Layout>
