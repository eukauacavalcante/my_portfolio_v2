---
import Button from "@/components/ui/Button.astro";
import { ShootingStars } from "@/components/ui/ShootingStars";
import { StarsBackground } from "@/components/ui/StarsBackground";
import { Image } from "astro:assets";
import errorImage from "../../public/not_found/not-found-image.svg";
import Layout from "@/layouts/layout.astro";
---

<Layout pageTitle="404 - Página Não Encontrada">
    <section class="relative flex w-full items-center justify-center border-b border-border px-4 py-12 sm:px-6 sm:py-16 md:px-8 md:py-20 lg:px-12 lg:py-24">
        <div class="relative z-10 flex w-full max-w-6xl flex-col items-center justify-center text-center md:flex-row md:text-left">

            <div class="flex w-full items-center justify-center md:w-1/2">
                <Image
                    src={errorImage}
                    alt="Ilustração de página não encontrada"
                    class="mx-auto w-full max-w-xs sm:max-w-sm md:max-w-full"
                    loading="eager"
                />
            </div>
            <div class="flex w-full flex-col items-center gap-4 md:w-1/2 md:items-start lg:gap-6">
                <h1 class="text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl xl:text-6xl">
                    Ops, página não encontrada!
                </h1>

                <p class="max-w-prose text-sm leading-relaxed text-muted-foreground sm:text-base md:text-lg">
                    // Você acessou um local que não existe e ficou perdido no
                    espaço sideral. Mas não se preocupe, o universo é cheio de
                    possibilidades! Vamos te levar de volta para a Terra.
                </p>

                <div class=" mt-2 w-full border-t border-border py-6 sm:mt-4">
                    <Button
                        href="/"
                        variant="default"
                        class="group border-0 text-base hover:scale-[1.02] sm:text-lg"
                    >
                        <svg class="transition group-hover:-translate-x-1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                            <g fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                <path stroke-dasharray="20" d="M21 12h-17.5">
                                    <animate fill="freeze" attributeName="stroke-dashoffset" dur="0.3s" values="20;0"/>
                                </path>
                                <path stroke-dasharray="12" stroke-dashoffset="12" d="M3 12l7 7M3 12l7 -7">
                                    <animate fill="freeze" attributeName="stroke-dashoffset" begin="0.3s" dur="0.2s" to="0" />
                                </path>
                            </g>
                        </svg>
                        Voltar para Home
                    </Button>
                </div>
            </div>
        </div>

        <ShootingStars client:only="react" />
        <StarsBackground client:only="react" />
    </section>
</Layout>
