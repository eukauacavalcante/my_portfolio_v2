---
import Button from "../ui/Button.astro";
import ThemeIcon from "../ui/ThemeIcon.astro";
---

<header class="sticky top-2 sm:top-4 z-50 w-full max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-3 items-center px-3 sm:px-4 md:px-6 py-2.5 sm:py-3.5 bg-background/50 backdrop-blur-2xl border border-border rounded-full">
    <div class="flex items-center gap-3 sm:gap-6 justify-start">
        <a href="/" class="text-lg md:text-xl font-extrabold">
            KC<span class="text-chart-1">.</span>
        </a>
        <ThemeIcon />
    </div>
    <nav class="hidden md:flex justify-center">
        <ul class="flex items-center gap-4 lg:gap-6 text-xs lg:text-sm text-muted-foreground font-mono">
            <li><a href="/#sobre-mim" class="hover:text-accent-foreground transition-colors">Sobre</a></li>
            <li><a href="/#servicos" class="hover:text-accent-foreground transition-colors">Serviços</a></li>
            <li><a href="/#projetos" class="hover:text-accent-foreground transition-colors">Projetos</a></li>
            <li><a href="/blog" class="hover:text-accent-foreground transition-colors">Blog</a></li>
            <li><a href="/#contato" class="hover:text-accent-foreground transition-colors">Contato</a></li>
        </ul>
    </nav>
    <div class="hidden md:flex justify-end">
        <Button variant="default" class="md:px-4 md:py-2 md:text-sm">
            Conecte-se
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                <path fill="currentColor" d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"/>
            </svg>
        </Button>
    </div>
</header>
