---
import { Icon } from "astro-iconify";
---

<footer class="w-full border-t border-border bg-background py-8 sm:py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-6">
        <span class="text-base md:text-2xl font-extrabold tracking-tight">Portfólio</span>
        <nav class="w-full">
            <ul class="flex flex-wrap justify-center items-center gap-x-6 gap-y-3 text-xs sm:text-sm font-mono text-muted-foreground">
                <li>
                    <a href="/" class="hover:text-primary transition-colors duration-200">// Home</a>
                </li>
                <li>
                    <a href="/#sobre-mim" class="hover:text-primary transition-colors duration-200">// Sobre</a>
                </li>
                <li>
                    <a href="/#servicos" class="hover:text-primary transition-colors duration-200">// Serviços</a>
                </li>
                <li>
                    <a href="/#projetos" class="hover:text-primary transition-colors duration-200">// Projetos</a>
                </li>
                <li>
                    <a href="/blog" class="hover:text-primary transition-colors duration-200">// Blog</a>
                </li>
                <li>
                    <a href="/#contato" class="hover:text-primary transition-colors duration-200">// Contato</a>
                </li>
            </ul>
        </nav>
        <div class="w-full flex flex-col md:flex-row justify-between items-center border-t border-border mt-6 pt-8 gap-6">
            <span class="text-[10px] sm:text-xs md:text-sm text-muted-foreground font-mono text-center md:text-left order-2 md:order-1">
                &copy; {new Date().getFullYear()} Kauã Cavalcante. Navegando pelo espaço digital.
            </span>
            <div class="flex items-center gap-4 order-1 md:order-2">
                <a
                    href="https://github.com/eukauacavalcante"
                    class="p-2 rounded-full border border-border hover:border-chart-1 hover:text-chart-1 hover:scale-110 hover:-translate-y-1 transition-all duration-300 ease-in-out bg-primary/5 antialiased"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub"
                >
                    <Icon name="mdi:github" width="20" height="20" />
                </a>
                <a
                    href="https://linkedin.com/in/eukauacavalcante"
                    class="p-2 rounded-full border border-border hover:border-chart-1 hover:text-chart-1 hover:scale-110 hover:-translate-y-1 transition-all duration-300 ease-in-out bg-primary/5 antialiased"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn"
                >
                    <Icon name="mdi:linkedin" width="20" height="20" />
                </a>
                <a
                    href="https://x.com/ikauacavalcante"
                    class="p-2 rounded-full border border-border hover:border-chart-1 hover:text-chart-1 hover:scale-110 hover:-translate-y-1 transition-all duration-300 ease-in-out bg-primary/5 antialiased"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Twitter"
                >
                    <Icon name="mdi:twitter" width="20" height="20" />
                </a>
            </div>
        </div>
    </div>
</footer>
