---
import ServicesCards from "../ui/ServicesCards";
---

<section id="servicos" class="min-h-svh flex flex-col gap-6 sm:gap-8 md:gap-10 justify-center items-center w-full py-8 sm:py-12 md:py-16 lg:py-20">
    <div class="flex flex-col gap-6 sm:gap-8 md:gap-10 justify-center items-center max-w-3xl text-center px-4 sm:px-6">
        <div class="flex flex-col gap-2 sm:gap-4 justify-center items-center">
            <div class="flex items-center gap-2 px-4 py-2 w-fit rounded-full bg-linear-to-r from-chart-1/10 to-chart-2/10 border border-chart-1/10 backdrop-blur">
                <span class="w-2 h-2 bg-chart-1 rounded-full animate-pulse"></span>
                <span class="text-[10px] sm:text-xs text-muted-foreground font-mono uppercase tracking-widest">
                    O que faço
                </span>
            </div>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl text-center font-extrabold">
                Meus<br>Serviços
            </h2>
        </div>
        <span class="text-sm sm:text-base text-muted-foreground font-mono">// Soluções especializadas elaboradas com precisão e inovação.</span>
    </div>
    <ServicesCards client:only="react" />
</section>
