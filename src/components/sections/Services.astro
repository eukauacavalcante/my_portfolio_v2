---
import SectionHeader from "../ui/SectionHeader.astro";
import services from "../../data/services";
---

<section id="servicos" class="max-w-7xl min-h-svh flex flex-col gap-6 sm:gap-8 md:gap-10 justify-center items-center w-full pt-24 lg:pt-32">
    <SectionHeader
        budgeText="O que faço"
        title="Meus Serviços"
        description="Soluções especializadas elaboradas com precisão e inovação."
    />
    <div class="w-full max-w-6xl grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 px-4 sm:px-6 md:px-8 cursor-default">
        {services.map((service) => (
            <article class="group relative h-full w-full rounded-2xl border border-border bg-card/80 p-6 shadow-sm transition-all duration-500 ease-out hover:-translate-y-2 hover:shadow-[0_15px_50px_-25px_var(--color-chart-1)]">
                <div class="flex flex-col items-center text-center gap-4">
                    <div class="flex h-16 w-16 items-center justify-center rounded-2xl border bg-linear-to-tr from-chart-1 to-chart-2 text-white" set:html={service.icon} />
                    <h4 class="text-lg sm:text-xl font-bold text-foreground group-hover:text-gradient duration-500 transition-all">
                        {service.title}
                    </h4>
                    <p class="text-xs sm:text-sm text-muted-foreground leading-relaxed">{service.description}</p>
                    <span class="mt-1 h-0.5 w-24 rounded-full bg-chart-1/25 transition-colors duration-500 group-hover:bg-linear-to-r group-hover:from-chart-1 group-hover:to-chart-2" />
                </div>
            </article>
        ))}
    </div>
</section>
