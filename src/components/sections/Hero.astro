---
import Button from "../ui/Button.astro";
import { ShootingStars } from '../ui/shooting-stars.tsx';
import { StarsBackground } from '../ui/stars-background.tsx';
---

<section id="hero" class="relative min-h-svh flex justify-center items-center border-b border-border w-full py-8 sm:py-12 md:py-16 lg:py-20">
    <div class="relative z-10 flex flex-col gap-6 sm:gap-8 md:gap-10 justify-center items-center max-w-3xl text-center px-4 sm:px-6">
        <div class="flex items-center gap-2 px-4 py-2 w-fit rounded-full bg-linear-to-r from-chart-1/10 to-chart-2/10 border border-chart-1/10 backdrop-blur">
				<span class="w-2 h-2 bg-chart-1 rounded-full animate-pulse"></span>
				<span class="text-[10px] sm:text-xs text-muted-foreground font-mono uppercase tracking-widest">
					Portfólio
				</span>
			</div>
		<h1 class="text-3xl sm:text-4xl lg:text-7xl font-extrabold">
			Kauã Cavalcante
		</h1>
		<p class="text-base sm:text-lg md:text-2xl text-muted-foreground max-w-2xl">
			Desenvolvedor Full Stack especializado em criar soluções escaláveis, seguras e modernas com foco em APIs robustas e experiência no desenvolvimento de sistemas end-to-end.
		</p>
		<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 w-full sm:w-auto px-4 sm:px-0">
			<Button href="#projetos" variant="default" size="md" class="hover:scale-[1.02] border-0 transition-all group">
				Ver Projetos
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256" class="transition-all duration-300 group-hover/btn:translate-x-1 group-hover/btn:scale-110">
                    <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path>
                </svg>
			</Button>
			<Button href="#contato" variant="outline" size="md">
				<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
				</svg>
				Fale Comigo
			</Button>
		</div>
		<div class="flex gap-3 sm:gap-4">
			<span class="w-7 h-7 sm:w-8 sm:h-8 bg-chart-1 rounded-full"></span>
			<span class="w-7 h-7 sm:w-8 sm:h-8 bg-chart-1 rounded-full"></span>
			<span class="w-7 h-7 sm:w-8 sm:h-8 bg-chart-1 rounded-full"></span>
		</div>
    </div>
    <ShootingStars client:only="react" />
    <StarsBackground client:only="react" />
</section>
