---
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";
import { Icon } from "astro-iconify";
---

<section class="px-4 sm:px-6 md:px-8">
    <Card size="full" hover={true} class="relative flex flex-col md:flex-row gap-8 items-stretch justify-between my-20 p-6 sm:p-10 lg:p-12 overflow-hidden cursor-default group border-border bg-linear-to-b from-card/50 to-card/20">
        <div class="w-full md:w-2/3 flex flex-col gap-5 justify-center items-start z-10">
            <div class="flex items-center gap-2 px-4 py-2 w-fit rounded-full bg-linear-to-r from-chart-1/10 to-chart-2/10 border border-chart-1/10 backdrop-blur">
                <span class="w-2 h-2 bg-chart-1 rounded-full animate-pulse"></span>
                <span class="text-[10px] sm:text-xs text-muted-foreground font-mono uppercase tracking-widest">
                    Novo
                </span>
            </div>
            <div class="space-y-3">
                <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.1] tracking-tight">
                    Blog Pessoal
                </h2>
                <p class="text-sm sm:text-lg text-muted-foreground leading-relaxed max-w-xl">
                    Compartilho minha jornada acadêmica em <span class="text-foreground font-medium">ADS</span>, tutoriais técnicos e reflexões sobre a evolução da tecnologia.
                </p>
            </div>
            <Button
                href="/blog"
                variant="default"
                size="lg"
                class="w-full dark:text-primary group/btn p-2 sm:p-4 bg-linear-to-r from-chart-1 to-chart-2 border-0 uppercase font-bold text-xs sm:text-base tracking-widest transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_-5px_var(--color-chart-1)]"
            >
                Acessar Blog
                <Icon name="mdi:arrow-right" class="w-5 h-5 transition-transform duration-300 group-hover/btn:translate-x-1" />
            </Button>
        </div>
        <div class="w-full md:w-1/3 flex justify-center items-center z-10">
            <div class="relative w-full aspect-square md:aspect-auto md:h-full max-w-75 md:max-w-none group/img">
                <div class="w-full h-full rounded-2xl bg-linear-to-br from-foreground/10 to-transparent border border-border p-4 backdrop-blur-md transform transition-all duration-500 group-hover:rotate-2 group-hover:scale-105 shadow-2xl shadow-black/50 flex flex-col gap-4">
                    <div class="w-full h-2/3 rounded-lg bg-chart-1/20 overflow-hidden flex items-center justify-center border border-border">
                        <Icon name="mdi:newspaper-variant-outline" class="w-16 h-16 text-chart-1 opacity-50 group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="space-y-2">
                        <div class="h-2 w-1/3 bg-chart-1/40 rounded-full"></div>
                        <div class="h-4 w-full bg-foreground/10 rounded-full"></div>
                        <div class="h-4 w-2/3 bg-foreground/10 rounded-full"></div>
                    </div>
                </div>
            </div>
        </div>
    </Card>
</section>
