---
import Button from "../ui/Button.astro";
---

<section id="contato" class="min-h-svh flex justify-center items-center w-full px-4 sm:px-8 lg:px-16 py-16 lg:py-24">
    <div class="w-full max-w-7xl flex flex-col lg:flex-row gap-12 lg:gap-16 justify-between items-center lg:items-start">
        <div class="w-full lg:w-1/2 flex flex-col gap-6 justify-center items-start">
            <div class="flex items-center gap-2 px-4 py-2 w-fit rounded-full bg-linear-to-r from-chart-1/10 to-chart-2/10 border border-chart-1/10 backdrop-blur">
                    <span class="w-2 h-2 bg-chart-1 rounded-full animate-pulse"></span>
                    <span class="text-[10px] sm:text-xs text-muted-foreground font-mono uppercase tracking-widest">
                        Contato
                    </span>
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight">
                Pronto para trabalhar<br class="hidden sm:block"/>
                em seu site?
            </h1>
            <span class="text-muted-foreground font-mono text-sm leading-relaxed">
                // Forneça o máximo de detalhes possível<br class="hidden sm:block" />
                e aguarde uma resposta em até 24 horas.
            </span>
            <div class="w-full flex justify-center items-center mt-4">
                <img
                    src="icons/world.svg"
                    alt="Ilustração de contato"
                    class="w-4/5 sm:w-2/3 lg:w-full max-w-sm lg:max-w-none opacity-90" 
                />
            </div>
        </div>
        <div class="w-full lg:w-1/2">
            <div class="w-full flex flex-col gap-6 px-6 sm:px-8 py-10 bg-card/50 border border-border rounded-2xl shadow-sm">
                <div class="flex flex-col gap-3">
                    <span class="text-sm sm:text-lg font-semibold text-foreground tracking-wide">
                        Com o que eu posso te ajudar?
                    </span>
                    <div class="flex flex-wrap gap-2">
                        <label class="px-4 py-2 border border-border text-xs text-muted-foreground font-semibold has-checked:bg-linear-to-r has-checked:from-chart-1 has-checked:to-chart-2 has-checked:text-white has-checked:border-transparent transition-all duration-200 uppercase rounded-xl cursor-pointer select-none">
                            <input type="checkbox" class="sr-only" />
                            Desenvolvimento Web
                        </label>
                        <label class="px-4 py-2 border border-border text-xs text-muted-foreground font-semibold has-checked:bg-linear-to-r has-checked:from-chart-1 has-checked:to-chart-2 has-checked:text-white has-checked:border-transparent transition-all duration-200 uppercase rounded-xl cursor-pointer select-none">
                            <input type="checkbox" class="sr-only" />
                            Informação
                        </label>
                        <label class="px-4 py-2 border border-border text-xs text-muted-foreground font-semibold has-checked:bg-linear-to-r has-checked:from-chart-1 has-checked:to-chart-2 has-checked:text-white has-checked:border-transparent transition-all duration-200 uppercase rounded-xl cursor-pointer select-none">
                            <input type="checkbox" class="sr-only" />
                            Outro
                        </label>
                    </div>
                </div>
                <div class="w-full h-px bg-border"></div>
                <form class="flex flex-col gap-5" novalidate>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <div class="flex flex-col gap-1.5 w-full">
                            <label for="name" class="text-xs text-muted-foreground font-mono uppercase tracking-widest">Nome</label>
                            <input
                                id="name"
                                type="text"
                                placeholder="João"
                                class="w-full px-4 py-2.5 bg-transparent border border-border rounded-lg text-sm text-foreground placeholder:text-muted-foreground/40 focus:outline-none focus:border-chart-1 focus:ring-1 focus:ring-chart-1/30 transition-all duration-200"
                            />
                        </div>
                        <div class="flex flex-col gap-1.5 w-full">
                            <label for="last-name" class="text-xs text-muted-foreground font-mono uppercase tracking-widest">Sobrenome</label>
                            <input
                                id="last-name"
                                type="text"
                                placeholder="Silva"
                                class="w-full px-4 py-2.5 bg-transparent border border-border rounded-lg text-sm text-foreground placeholder:text-muted-foreground/40 focus:outline-none focus:border-chart-1 focus:ring-1 focus:ring-chart-1/30 transition-all duration-200"
                            />
                        </div>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label for="email" class="text-xs text-muted-foreground font-mono uppercase tracking-widest">Email</label>
                        <input
                            id="email"
                            type="email"
                            placeholder="joao@exemplo.com"
                            class="w-full px-4 py-2.5 bg-transparent border border-border rounded-lg text-sm text-foreground placeholder:text-muted-foreground/40 focus:outline-none focus:border-chart-1 focus:ring-1 focus:ring-chart-1/30 transition-all duration-200"
                        />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label for="message" class="text-xs text-muted-foreground font-mono uppercase tracking-widest">Mensagem</label>
                        <textarea
                            id="message"
                            rows="4"
                            placeholder="Conte um pouco sobre o motivo do seu contato..."
                            class="w-full px-4 py-2.5 bg-transparent border border-border rounded-lg text-sm text-foreground placeholder:text-muted-foreground/40 focus:outline-none focus:border-chart-1 focus:ring-1 focus:ring-chart-1/30 transition-all duration-200 resize-none"
                        ></textarea>
                    </div>
                    <Button variant="default" size="md" class="w-full mt-1 dark:text-primary bg-linear-to-r from-chart-1 to-chart-2 hover:from-chart-1/50 hover:chart-2/50 hover:scale-[1.02] border-0 transition-all duration-300 uppercase group">
                        Enviar
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256" class="transition-transform duration-300 group-hover:translate-x-1 group-hover:scale-110">
                            <path d="M227.32,28.68a16,16,0,0,0-15.66-4.08l-.15,0L19.57,82.84a16,16,0,0,0-2.49,29.8L102,154l41.3,84.87A15.86,15.86,0,0,0,157.74,248q.69,0,1.38-.06a15.88,15.88,0,0,0,14-11.51l58.2-191.94c0-.05,0-.1,0-.15A16,16,0,0,0,227.32,28.68ZM157.83,231.85l-.05.14,0-.07-40.06-82.3,48-48a8,8,0,0,0-11.31-11.31l-48,48L24.08,98.25l-.07,0,.14,0L216,40Z"></path>
                        </svg>
                    </Button>
                </form>
            </div>
        </div>
    </div>
</section>
