---
import Card from "../ui/Card.astro";
import StackData from "../../data/stack.ts";
---

<section id="stack" class="min-h-dvh flex flex-col gap-4 justify-center items-center w-full mb-20">
	<div class="flex flex-col gap-8 justify-center items-center max-w-3xl text-center mb-4 lg:mb-8">
		<div class="flex items-center gap-2 px-4 py-2 w-fit rounded-full bg-linear-to-r from-chart-1/10 to-chart-2/10 border border-chart-1/10 backdrop-blur">
            <span class="w-2 h-2 bg-chart-1 rounded-full animate-pulse"></span>
            <span class="text-xs text-muted-foreground font-mono uppercase tracking-widest">
                Ferramentas
            </span>
        </div>
		<h1 class="text-3xl sm:text-4xl lg:text-5xl text-center font-extrabold">
			Meu<br>Universo Tech
		</h1>
		<span class="text-muted-foreground font-mono">// Navegando pelo espaço digital com uma constelação robusta de tecnologias, frameworks e ferramentas projetadas para escalabilidade e performance.</span>
	</div>
	<div class="flex flex-col gap-10 justify-center items-center w-full px-4">
		<div class="w-full">
			<div class="flex flex-col justify-start items-start gap-4 mb-8">
				<div class="flex flex-row gap-4 items-center">
					<h2 class="text-xl lg:text-2xl xl:text-3xl font-extrabold">
						Engenharia Frontend
					</h2>
					<span class="w-20 sm:w-30 lg:w-50 h-0.5 bg-linear-to-r from-chart-1 to-chart-1/10"></span>
				</div>
				<p class="text-sm sm:text-base text-muted-foreground text-left max-w-2xl font-mono">
					// Construindo interfaces de usuário imersivas, responsivas e performáticas com bibliotecas e frameworks de ponta.
				</p>
			</div>
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 lg:grid-cols-6 gap-4">
				{StackData.frontend.map((tech) => (
					<Card size="sm" hover={true} class="flex flex-col gap-3 justify-center items-center">
						<div class="w-12 h-12 bg-chart-1/10 rounded-lg flex items-center justify-center">
							<span class="text-2xl">💻</span>
						</div>
						<span class="text-sm font-semibold text-center">{tech.name}</span>
					</Card>
				))}
			</div>
		</div>
		<div class="w-full">
			<div class="flex flex-col justify-start items-start gap-4 mb-8">
				<div class="flex flex-row gap-4 items-center">
					<h2 class="text-xl lg:text-2xl xl:text-3xl font-extrabold">
						Backend e Arquitetura
					</h2>
					<span class="w-20 sm:w-30 lg:w-50 h-0.5 bg-linear-to-r from-chart-1 to-chart-1/10"></span>
				</div>
				<p class="text-sm sm:text-base text-muted-foreground text-left max-w-2xl font-mono">
					// Soluções robustas no lado do servidor, gerenciamento de bancos de dados e infraestrutura escalável.
				</p>
			</div>
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 lg:grid-cols-6 gap-4">
				{StackData.backend.map((tech) => (
					<Card size="sm" hover={true} class="flex flex-col gap-3 justify-center items-center">
						<div class="w-12 h-12 bg-chart-1/10 rounded-lg flex items-center justify-center">
							<span class="text-2xl">⚙️</span>
						</div>
						<span class="text-sm font-semibold text-center">{tech.name}</span>
					</Card>
				))}
			</div>
		</div>
	</div>
</section>
