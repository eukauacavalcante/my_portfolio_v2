---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import Project from "../../data/project.ts";
---

<section id="projetos" class="min-h-svh flex flex-col gap-4 justify-center items-center w-full px-4 pt-24 lg:pt-32 scroll-mt-20">
	<div class="flex flex-col gap-8 justify-center items-center max-w-3xl text-center mb-4 lg:mb-8">
		<div class="flex flex-col gap-2 sm:gap-4 justify-center items-center">
			<div class="flex items-center gap-2 px-4 py-2 w-fit rounded-full bg-linear-to-r from-chart-1/10 to-chart-2/10 border border-chart-1/10 backdrop-blur">
				<span class="w-2 h-2 bg-chart-1 rounded-full animate-pulse"></span>
				<span class="text-[10px] sm:text-xs text-muted-foreground font-mono uppercase tracking-widest">
					projetos
				</span>
			</div>
			<h1 class="text-3xl sm:text-4xl lg:text-5xl text-center font-extrabold">
				Projetos de<br>Destaque
			</h1>
		</div>
		<span class="text-muted-foreground font-mono">
            // Projetos onde coloquei a mão na massa e desenvolvi aplicações modernas, adequadas para o mercado de tecnologia
        </span>
	</div>
    <div class="w-full max-w-7xl flex flex-col gap-6 md:gap-8 lg:gap-12 justify-center items-start sm:px-6 lg:px-8">
        { Project.map((project, index) => (
            <Card size="full" hover={true} class="group flex flex-col gap-4 justify-center items-center w-full">
                <div class="w-full flex flex-col lg:flex-row gap-6 lg:gap-8 xl:gap-10">
                    <div class="w-full lg:w-3/5 bg-chart-1/10 rounded-lg aspect-video shrink-0 order-2 lg:order-1"></div>
                    <div class="w-full lg:w-2/5 flex flex-col gap-3 justify-center items-start order-1 lg:order-2">
                        <div class="w-full flex flex-row gap-4 justify-between items-center">
                            <span class="text-xs text-muted-foreground font-mono uppercase">
                                {project.date}
                            </span>
                            <span class="w-8 h-8 flex items-center justify-center border border-border rounded-full text-sm text-muted-foreground font-mono leading-none shrink-0 group-hover:text-chart-1 transition-colors">
                                0{index + 1}
                            </span>
                        </div>
                        <div class="flex flex-col gap-1.5 mb-2 sm:mb-4">
                            <span class="text-2xl sm:text-3xl lg:text-4xl font-extrabold leading-tight group-hover:text-chart-1 transition-colors">
                                {project.title}
                            </span>
                            <span class="text-sm text-muted-foreground font-mono">
                                // {project.phrase}
                            </span>
                        </div>
                        <p class="text-sm sm:text-base text-muted-foreground leading-relaxed">{project.resume}</p>
                        <div class="w-full flex flex-col sm:flex-row gap-3 justify-between items-start sm:items-center mt-4">
                            <div class="flex flex-row flex-wrap gap-2">
                                {project.tags.map((tag) => (
                                    <span class="text-xs text-muted-foreground uppercase bg-chart-1/10 border border-border px-3 py-1.5 rounded-xl">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                            <div class="shrink-0">
                                <Button
                                    href={project.slug}
                                    variant="outline"
                                    size="sm"
                                    class="px-4 sm:px-6 py-3 sm:py-4 border border-border text-primary uppercase group/btn hover:scale-[1.02] hover:border-chart-1/60 hover:text-chart-1 hover:shadow-lg hover:shadow-chart-1/20"
                                >
                                    Ver mais
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256" class="transition-all duration-300 group-hover/btn:translate-x-1 group-hover/btn:scale-110">
                                        <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path>
                                    </svg>
                                </Button>
                            </div>
                        </div>
                    </div>
                </div>
            </Card>
        ))}
    </div>
</section>
