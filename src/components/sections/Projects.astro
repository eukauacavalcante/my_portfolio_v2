---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import Project from "../../data/project.ts";
import SectionHeader from "../ui/SectionHeader.astro";
---

<section id="projetos" class="max-w-7xl flex flex-col gap-4 justify-center items-center w-full pt-24 lg:pt-32">
    <SectionHeader
        budgeText="Projetos"
        title="Projetos de Destaque"
        description="Projetos onde coloquei a mão na massa e desenvolvi aplicações modernas, adequadas para o mercado de tecnologia"
    />
    <div class="w-full max-w-5xl flex flex-col gap-6 md:gap-8 lg:gap-12 justify-center items-start">
        { Project.map((project, index) => {
            return (
                <Card size="full" hover={true} class="flex flex-col gap-4 justify-center items-center w-full group">
                    <div class="w-full flex flex-col lg:flex-row gap-6 lg:gap-8 xl:gap-10">
                        <div class="w-full lg:w-3/5 bg-linear-to-tr from-chart-1/10 to-chart-2/10 rounded-lg aspect-video shrink-0 order-2 lg:order-1">
                            {project.images[0] ? (
                                <img
                                    src={project.images[0]}
                                    alt={project.title}
                                    width="800"
                                    height="450"
                                    loading="lazy"
                                    class="w-full h-full object-cover rounded-lg"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24">
                                        <path fill="currentColor" d="M17 12c0 .54-.1 1.05-.26 1.54L15 11.78A3.06 3.06 0 0 0 12.22 9l-1.76-1.74c.49-.16 1-.26 1.54-.26c2.76 0 5 2.24 5 5M9.88 4h4.24l1.83 2H20v10.8l1.88 1.88c.08-.21.12-.44.12-.68V6c0-1.11-.89-2-2-2h-3.17L15 2H9L7.18 4L8.6 5.4zm12.23 17.46l-1.27 1.27L18.11 20H4a2 2 0 0 1-2-2V6c0-.58.25-1.1.65-1.46L1.11 3l1.28-1.27zM9 12c0 1.66 1.34 3 3 3c.33 0 .65-.07.94-.17l-3.77-3.77c-.1.3-.17.61-.17.94m7.11 6l-1.66-1.66c-.73.41-1.56.66-2.45.66c-2.76 0-5-2.24-5-5c0-.89.25-1.72.66-2.45L4.11 6H4v12z"/>
                                    </svg>
                                </div>
                            )}
                        </div>
                        <div class="w-full lg:w-2/5 flex flex-col gap-3 justify-center items-start order-1 lg:order-2">
                            <div class="w-full flex flex-row gap-4 justify-between items-center">
                                <span class="text-xs text-muted-foreground font-mono uppercase">
                                    {project.date}
                                </span>
                                <span class="w-8 h-8 flex items-center justify-center border border-border rounded-full text-sm text-muted-foreground font-mono leading-none shrink-0 group-hover:text-gradient duration-500 transition-all">
                                    0{index + 1}
                                </span>
                            </div>
                            <div class="flex flex-col gap-1.5 mb-2 sm:mb-4">
                                <span class="text-2xl sm:text-3xl lg:text-4xl font-extrabold leading-tight group-hover:text-gradient duration-500 transition-all">
                                    {project.title}
                                </span>
                                <span class="text-sm text-muted-foreground font-mono">
                                    // {project.phrase}
                                </span>
                            </div>
                            <div class="flex flex-row flex-wrap gap-2">
                                {project.tags.map((tag) => (
                                    <span class="text-xs text-muted-foreground uppercase bg-chart-1/10 border border-border px-3 py-1.5 rounded-xl">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                            <Button
                                href={`/projetos/${project.slug}`}
                                size="full"
                                class="px-4 py-2 text-sm sm:px-6 sm:py-3 sm:text-base dark:text-primary bg-linear-to-r from-chart-1 to-chart-2 border-0 uppercase group/btn"
                            >
                                Ver {project.title}
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256" class="transition-all duration-300 group-hover/btn:translate-x-1 group-hover/btn:scale-110">
                                    <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path>
                                </svg>
                            </Button>
                        </div>
                    </div>
                </Card>
            );
        })}
    </div>
</section>
