---
interface Props {
	title?: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
	ogType?: "website" | "profile";
	twitterHandle?: string;
	socialLinks?: string[];
}

const {
	title = "Kauã Cavalcante | Desenvolvedor Full Stack",
	description = "Portfolio de Kauã Cavalcante, desenvolvedor full stack que cria aplicações modernas com Django, Next.js, Astro e APIs REST focadas em performance e UX.",
	canonicalUrl = "https://kauacavalcante.vercel.app/",
	ogImage = "https://kauacavalcante.vercel.app/og-banner.png",
	ogType = "website",
	twitterHandle = "@ikauacavalcante",
	socialLinks = [
		"https://github.com/eukauacavalcante",
		"https://www.linkedin.com/in/eukauacavalcante",
        "https://x.com/ikauacavalcante"
	],
} = Astro.props as Props;

const siteUrl = import.meta.env.SITE;
const normalizedCanonical = canonicalUrl.startsWith("https://")
	? canonicalUrl
	: new URL(canonicalUrl, siteUrl).toString();
const normalizedOgImage = ogImage.startsWith("https://")
	? ogImage
	: new URL(ogImage, siteUrl).toString();
const personJsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Kauã Cavalcante",
	url: siteUrl,
	jobTitle: "Desenvolvedor Full Stack",
	description,
    image: normalizedOgImage,
	sameAs: socialLinks,
    knowsAbout: [
        "Django",
        "Next.js",
        "Astro",
        "APIs REST"
    ]
});
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#0f172a" />
<title>{title}</title>
<link rel="icon" href="/favicon.ico" />
<meta name="description" content={description} />
<meta name="author" content="Kauã Cavalcante" />
<link rel="canonical" href={normalizedCanonical} />
<link rel="sitemap" href="/sitemap.xml" />

<meta property="og:title" content={title} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={normalizedCanonical} />
<meta property="og:description" content={description} />
<meta property="og:image" content={normalizedOgImage} />
<meta property="og:image:alt" content="Banner do portfolio de Kauã Cavalcante" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="pt_BR" />
<meta property="og:site_name" content="Kauã Cavalcante" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={normalizedOgImage} />
<meta name="twitter:image:alt" content="Banner do portfolio de Kauã Cavalcante" />
<meta name="twitter:site" content="@ikauacavalcante" />
{twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}

<!-- TODO: create apple-touch-icon 180x180 -->

<script type="application/ld+json" set:html={personJsonLd}></script>
