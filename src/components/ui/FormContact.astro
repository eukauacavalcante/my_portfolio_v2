<div class="form-contact-wrapper">
  <form id="contact-form" class="form-contact-form" novalidate>
    <div
      style="position:absolute; left:-9999px; opacity:0; pointer-events:none"
      aria-hidden="true"
    >
      <label for="_trap">Não preencha</label>
      <input
        type="text"
        id="_trap"
        name="_trap"
        tabindex="-1"
        autocomplete="off"
      />
    </div>
    <div class="form-contact-checkboxes">
      <span class="form-contact-checkboxes-title"
        >Com o que eu posso te ajudar?</span
      >
      <div class="form-contact-checkboxes-group" id="reasons-group">
        <label class="checkbox-label">
          <input
            type="radio"
            class="checkbox-input"
            value="Freelance/Projeto"
            name="reasons"
          />
          Freelance/Projeto
        </label>
        <label class="checkbox-label">
          <input
            type="radio"
            class="checkbox-input"
            value="Dúvida"
            name="reasons"
          />
          Dúvida
        </label>
        <label class="checkbox-label">
          <input
            type="radio"
            class="checkbox-input"
            value="Outro"
            name="reasons"
          />
          Outro
        </label>
      </div>
      <span id="reasons-error" class="field-error hidden"></span>
    </div>
    <div class="form-contact-divider"></div>
    <div class="form-contact-row">
      <div class="form-contact-field">
        <label for="name" class="label-base">Nome</label>
        <input
          id="name"
          name="name"
          type="text"
          placeholder="João"
          class="input-base"
        />
        <span id="name-error" class="field-error hidden"></span>
      </div>
      <div class="form-contact-field">
        <label for="last-name" class="label-base">Sobrenome</label>
        <input
          id="last-name"
          name="lastName"
          type="text"
          placeholder="Silva"
          class="input-base"
        />
        <span id="lastName-error" class="field-error hidden"></span>
      </div>
    </div>
    <div class="form-contact-field">
      <label for="email" class="label-base">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        placeholder="joao@exemplo.com"
        class="input-base"
      />
      <span id="email-error" class="field-error hidden"></span>
    </div>
    <div class="form-contact-field">
      <label for="message" class="label-base">Mensagem</label>
      <textarea
        id="message"
        name="message"
        rows="4"
        placeholder="Conte um pouco sobre o motivo do seu contato..."
        class="input-base resize-none"></textarea>
      <span id="message-error" class="field-error hidden"></span>
    </div>

    <p id="form-success" class="hidden text-green-500 text-sm font-medium">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        ><g
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          ><path d="M11 19H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6"
          ></path><path d="m3 7l9 6l9-6m-6 12l2 2l4-4"></path></g
        ></svg
      >
      Mensagem enviada! Responderei em até 24h.
    </p>

    <p id="form-global-error" class="hidden text-red-500 text-sm font-medium">
    </p>

    <button
      type="submit"
      id="submit-btn"
      class="w-full mt-1 dark:text-primary bg-linear-to-r from-chart-1 to-chart-2 hover:scale-[1.02] border-0 transition-all duration-300 uppercase group inline-flex items-center justify-center gap-2 font-semibold px-4 py-2 text-sm sm:px-6 sm:py-3 sm:text-base rounded-lg cursor-pointer disabled:opacity-50"
      )
    >
      <span id="btn-label">Enviar</span>
      <span id="btn-loading" class="hidden">Enviando...</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        fill="currentColor"
        viewBox="0 0 256 256"
        class="transition-transform duration-300 group-hover:translate-x-1 group-hover:scale-110"
      >
        <path
          d="M227.32,28.68a16,16,0,0,0-15.66-4.08l-.15,0L19.57,82.84a16,16,0,0,0-2.49,29.8L102,154l41.3,84.87A15.86,15.86,0,0,0,157.74,248q.69,0,1.38-.06a15.88,15.88,0,0,0,14-11.51l58.2-191.94c0-.05,0-.1,0-.15A16,16,0,0,0,227.32,28.68ZM157.83,231.85l-.05.14,0-.07-40.06-82.3,48-48a8,8,0,0,0-11.31-11.31l-48,48L24.08,98.25l-.07,0,.14,0L216,40Z"
        ></path>
      </svg>
    </button>
  </form>
</div>

<style>
  .field-error {
    color: #ef4444;
    font-size: 0.75rem;
    margin-top: 0.25rem;
    display: block;
  }
  .hidden {
    display: none !important;
  }
  .input-error {
    border-color: #ef4444 !important;
  }
</style>

<script>
  let isSuccess = false;
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnLabel = document.getElementById("btn-label")!;
  const btnLoading = document.getElementById("btn-loading")!;
  const successMsg = document.getElementById("form-success")!;
  const globalError = document.getElementById("form-global-error")!;

  function showError(id: string, msg: string) {
    const el = document.getElementById(`${id}-error`);
    const input =
      document.getElementById(id) || document.querySelector(`[name="${id}"]`);
    if (el) {
      el.textContent = msg;
      el.classList.remove("hidden");
    }
    if (input) input.classList.add("input-error");
  }

  function clearErrors() {
    document.querySelectorAll(".field-error").forEach((el) => {
      el.textContent = "";
      el.classList.add("hidden");
    });
    document
      .querySelectorAll(".input-error")
      .forEach((el) => el.classList.remove("input-error"));
    globalError.classList.add("hidden");
    globalError.textContent = "";
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    const data = new FormData(form);
    const reason = data.get("reasons") as string;

    const payload = {
      name: ((data.get("name") as string) ?? "").trim(),
      lastName: ((data.get("lastName") as string) ?? "").trim(),
      email: ((data.get("email") as string) ?? "").trim(),
      message: ((data.get("message") as string) ?? "").trim(),
      _trap: (data.get("_trap") as string) ?? "",
      reason: reason ? [reason] : [],
    };

    // client-side basic validation (mirrors the backend)
    let hasError = false;
    if (!payload.name || payload.name.length < 2) {
      showError("name", "Nome deve ter ao menos 2 caracteres.");
      hasError = true;
    }
    if (!payload.lastName || payload.lastName.length < 2) {
      showError("lastName", "Sobrenome deve ter ao menos 2 caracteres.");
      hasError = true;
    }
    if (!payload.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email)) {
      showError("email", "Email inválido.");
      hasError = true;
    }
    if (!payload.message || payload.message.length < 20) {
      showError("message", "Mensagem deve ter ao menos 20 caracteres.");
      hasError = true;
    }
    if (!reason) {
      showError("reasons", "Selecione um motivo.");
      hasError = true;
    }
    if (hasError) return;

    btnLabel.classList.add("hidden");
    btnLoading.classList.remove("hidden");
    submitBtn.disabled = true;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const json = await res.json();

      if (res.ok) {
        isSuccess = true;
        form.reset();
        successMsg.classList.remove("hidden");
        successMsg.classList.add("flex", "items-center", "gap-1");
        btnLabel.textContent = "Mensagem enviada";
      } else if (res.status === 422 && json.errors) {
        submitBtn.disabled = false;
        for (const [field, msgs] of Object.entries(
          json.errors as Record<string, string[]>,
        )) {
          showError(field, msgs[0]);
        }
      } else {
        submitBtn.disabled = false;
        globalError.textContent =
          json.error ?? "Algo deu errado. Tente novamente.";
        globalError.classList.remove("hidden");
      }
    } catch {
      submitBtn.disabled = false;
      globalError.textContent = "Falha de conexão. Verifique sua internet.";
      globalError.classList.remove("hidden");
    } finally {
      if (!isSuccess) {
        btnLabel.classList.remove("hidden");
      }
      btnLoading.classList.add("hidden");
    }
  });
</script>
