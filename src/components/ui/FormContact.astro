---
import Button from "../ui/Button.astro";
---

<div class="form-contact-wrapper">
    <div class="form-contact-checkboxes">
        <span class="form-contact-checkboxes-title">
            Com o que eu posso te ajudar?
        </span>
        <div class="form-contact-checkboxes-group">
            <label class="checkbox-label">
                <input type="checkbox" class="checkbox-input" />
                Desenvolvimento Web
            </label>
            <label class="checkbox-label">
                <input type="checkbox" class="checkbox-input" />
                Informação
            </label>
            <label class="checkbox-label">
                <input type="checkbox" class="checkbox-input" />
                Outro
            </label>
        </div>
    </div>

    <div class="form-contact-divider"></div>

    <form class="form-contact-form" novalidate>
        <div class="form-contact-row">
            <div class="form-contact-field">
                <label for="name" class="label-base">Nome</label>
                <input
                    id="name"
                    type="text"
                    placeholder="João"
                    class="input-base"
                />
            </div>
            <div class="form-contact-field">
                <label for="last-name" class="label-base">Sobrenome</label>
                <input
                    id="last-name"
                    type="text"
                    placeholder="Silva"
                    class="input-base"
                />
            </div>
        </div>

        <div class="form-contact-field">
            <label for="email" class="label-base">Email</label>
            <input
                id="email"
                type="email"
                placeholder="joao@exemplo.com"
                class="input-base"
            />
        </div>

        <div class="form-contact-field">
            <label for="message" class="label-base">Mensagem</label>
            <textarea
                id="message"
                rows="4"
                placeholder="Conte um pouco sobre o motivo do seu contato..."
                class="input-base resize-none"
            ></textarea>
        </div>

        <Button
            variant="default"
            size="responsive"
            class="w-full mt-1 dark:text-primary bg-linear-to-r from-chart-1 to-chart-2 hover:scale-[1.02] border-0 transition-all duration-300 uppercase group"
        >
            Enviar
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256" class="transition-transform duration-300 group-hover:translate-x-1 group-hover:scale-110">
                <path d="M227.32,28.68a16,16,0,0,0-15.66-4.08l-.15,0L19.57,82.84a16,16,0,0,0-2.49,29.8L102,154l41.3,84.87A15.86,15.86,0,0,0,157.74,248q.69,0,1.38-.06a15.88,15.88,0,0,0,14-11.51l58.2-191.94c0-.05,0-.1,0-.15A16,16,0,0,0,227.32,28.68ZM157.83,231.85l-.05.14,0-.07-40.06-82.3,48-48a8,8,0,0,0-11.31-11.31l-48,48L24.08,98.25l-.07,0,.14,0L216,40Z"></path>
            </svg>
        </Button>
    </form>
</div>
