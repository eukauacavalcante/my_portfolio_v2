---
import type { HTMLAttributes } from "astro/types";
import { twMerge } from "tailwind-merge";

interface Props extends HTMLAttributes<"a"> {
    href?: string;
    variant?: "default" | "outline";
    size?: "responsive" | "lg" | "full";
    class?: string;
}

const { 
    href = "#", 
    variant = "default", 
    size = "responsive",
    class: className = "",
    ...props
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center gap-2 font-semibold transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed";

const variantStyles = {
    default: "bg-foreground text-primary-foreground rounded-lg hover:bg-foreground/80 active:scale-95",
    outline: "bg-transparent border-2 border-border text-foreground rounded-lg hover:text-accent-foreground hover:border-accent-foreground/50",
};

const sizeStyles = {
    responsive: "px-4 py-2 text-sm sm:px-6 sm:py-3 sm:text-base",
    lg: "px-8 py-4 text-lg",
    full: "w-full px-6 py-3 text-base"
};

const buttonClasses = twMerge(baseStyles, variantStyles[variant], sizeStyles[size], className);
---

<a href={href} class={buttonClasses} {...props}>
    <slot />
</a>
