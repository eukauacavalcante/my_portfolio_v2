---
import { twMerge } from "tailwind-merge";

interface Props {
    size?: "sm" | "md" | "lg" | "full";
    class?: string;
    hover?: boolean;
}

const { 
    size = "md",
    class: className = "",
    hover = false
} = Astro.props;

const baseStyles = "bg-card/50 border border-border rounded-2xl transition-all duration-200";

const sizeStyles = {
    sm: "p-4 w-35 h-25 sm:w-45 sm:h-35",
    md: "p-6 w-full max-w-md",
    lg: "p-8 w-full max-w-lg",
    full: "p-6 w-full"
};

const hoverStyles = hover ? "hover:shadow-2xl hover:shadow-chart-1/20 hover:border-chart-1/50 hover:-translate-y-1" : "";

const cardClasses = twMerge(baseStyles, sizeStyles[size], hoverStyles, className);
---

<div class={cardClasses}>
    <slot />
</div>
